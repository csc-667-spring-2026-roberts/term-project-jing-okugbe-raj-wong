<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Scrabble Lobby</title>
  <link rel="stylesheet" href="/css/home.css">
  <script src="/js/lobby.js" defer></script>
</head>
<body>
  <nav>
    <a href="/">Home</a>
    <% if (typeof user !== "undefined" && user) { %>
      <span>Welcome, <%= user.email %>!</span>
      <form action="/auth/logout" method="POST" style="display:inline">
        <button type="submit">Logout</button>
      </form>
    <% } else { %>
      <a href="/auth/login">Login</a>
      <a href="/auth/register">Register</a>
    <% } %>
  </nav>

  <main>
    <h1>Scrabble Lobby</h1>
    <p id="status-message">Loading games...</p>

    <section class="card">
      <h2>Create Game</h2>
      <form action="/games" method="POST">
        <button type="submit">Create New Scrabble Game</button>
      </form>
    </section>

    <section class="card">
      <h2>Open Games (waiting for players)</h2>
      <ul id="games-list">
        <li><em>Loading...</em></li>
      </ul>
    </section>
  </main>
</body>
</html>