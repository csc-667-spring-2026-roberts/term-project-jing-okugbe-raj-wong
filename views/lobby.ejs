<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Scrabble Lobby</title>
  <link rel="stylesheet" href="/css/home.css">
  <script src="/js/lobby.js" defer></script>
</head>
<body>
  <nav>
    <a href="/">Home</a>
    <a href="/lobby">Lobby</a>
    <a href="/rules">Rules</a>
    <% if (typeof user !== "undefined" && user) { %>
      <span>Welcome, <%= user.email %></span>
      <form action="/auth/logout" method="POST">
        <button type="submit">Logout</button>
      </form>
    <% } else { %>
      <a href="/auth/login">Login</a>
      <a href="/auth/register">Register</a>
    <% } %>
  </nav>

  <main>
    <section class="hero">
      <h1>Scrabble Lobby</h1>
      <p>Start a new match, join an open table, and play live with 2 to 4 players.</p>
      <p id="status-message">Loading games...</p>
      <div class="hero-actions">
        <form action="/games" method="POST">
          <button type="submit">Create New Game</button>
        </form>
        <a class="button secondary" href="/rules">Read Rules</a>
      </div>
    </section>

    <section class="card wide">
      <h2>Open Games</h2>
      <p>Waiting games are listed here. A game can start with 2 players and supports up to 4 players.</p>
      <ul id="games-list">
        <li><em>Loading...</em></li>
      </ul>
    </section>

    <template id="empty-games-template">
      <li><em>No open games right now. Create one above.</em></li>
    </template>

    <template id="game-row-template">
      <li>
        <span>
          <span class="game-title"></span>
          <span class="game-creator"></span>
          <span class="game-player-count"></span>
        </span>
        <a class="game-link">Open</a>
      </li>
    </template>
  </main>
</body>
</html>
