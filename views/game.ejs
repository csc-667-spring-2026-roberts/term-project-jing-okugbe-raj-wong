<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Scrabble Game #<%= gameId %></title>
  <link rel="stylesheet" href="/css/home.css">
  <script src="/js/game.js" defer></script>
</head>
<body>
  <nav>
    <a href="/">Home</a>
    <a href="/lobby">Lobby</a>
    <a href="/rules">Rules</a>
    <% if (typeof user !== "undefined" && user) { %>
      <span>Welcome, <%= user.email %></span>
      <form action="/auth/logout" method="POST">
        <button type="submit">Logout</button>
      </form>
    <% } %>
  </nav>

  <main
    data-game-id="<%= gameId %>"
    data-current-user-id="<%= user.id %>"
  >
    <section class="hero">
      <h1>Game #<%= gameId %></h1>
      <p>Place tiles, submit whole words, replace used tiles from the bag, and take turns live.</p>
      <p id="status-message">Connecting to live updates...</p>
    </section>

    <% if (errorMessage) { %>
      <div class="alert-error"><%= errorMessage %></div>
    <% } %>

    <section class="card wide">
      <div class="stats-grid">
        <div class="stat-box">
          <span class="stat-label">Status</span>
          <span class="stat-value" id="game-status"><%= game.status %></span>
        </div>
        <div class="stat-box">
          <span class="stat-label">Current Turn</span>
          <span class="stat-value" id="turn-indicator">
            <%= game.current_turn_user_id ? game.current_turn_user_id : "\u2014" %>
          </span>
        </div>
        <div class="stat-box">
          <span class="stat-label">Tiles Left</span>
          <span class="stat-value" id="tiles-remaining"><%= game.tiles_remaining %></span>
        </div>
      </div>
    </section>

    <section class="card wide">
      <h2>Players</h2>
      <ul id="players-list">
        <% game.players.forEach(function(p) { %>
          <li data-user-id="<%= p.user_id %>">
            <%= p.email %> &mdash; <span class="player-score"><%= p.score %></span> pts
          </li>
        <% }); %>
      </ul>
    </section>

    <section class="card wide">
      <h2>Game Controls</h2>
      <p>Maximum 4 players. The match can start once at least 2 players have joined.</p>

      <% if (game.status === "waiting") { %>
        <% var inGame = game.players.some(function(p){ return p.user_id === user.id; }); %>
        <% var gameFull = game.players.length >= 4; %>

        <div class="game-actions">
          <% if (!inGame && !gameFull) { %>
            <form action="/games/<%= gameId %>/join" method="POST">
              <button type="submit">Join This Game</button>
            </form>
          <% } else if (!inGame && gameFull) { %>
            <p><em>This game is full.</em></p>
          <% } %>

          <% if (inGame && game.players.length >= 2) { %>
            <form action="/games/<%= gameId %>/start" method="POST">
              <button type="submit">Start Game</button>
            </form>
          <% } else if (inGame) { %>
            <p><em>Waiting for at least 2 players to start.</em></p>
          <% } %>
        </div>
      <% } %>
    </section>

    <section class="card wide game-board-card">
      <h2>Board</h2>
      <div id="board-grid" class="board-grid"></div>
    </section>

    <section class="card wide">
      <h2>Your Rack</h2>
      <div id="rack"></div>
      <div class="game-actions">
        <button id="submit-word" disabled>Submit Word</button>
        <button id="clear-placements" class="secondary" disabled>Clear</button>
        <button id="pass-turn" class="secondary" disabled>Pass Turn</button>
      </div>
      <p class="footer-note">Select a tile from your rack, then click a board cell to place it. Click a pending tile to remove it.</p>
    </section>
  </main>
</body>
</html>
